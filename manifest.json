{
  "manifest_version": 3,
  "name": "Twitter Guardian - AI Spam Filter",
  "version": "1.0",
  "description": "Autonomous Twitter spam detection and account management",

  "permissions": [
    "storage",
    "activeTab"
  ],

  "host_permissions": [
    "https://x.com/*",
    "https://twitter.com/*"
  ],

  "content_scripts": [
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "js": ["content-script.js"],
      "css": ["styles.css"],
      "run_at": "document_end"
    }
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "Twitter Guardian"
  },

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}